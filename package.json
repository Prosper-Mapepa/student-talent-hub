{
  "name": "veritalent",
  "version": "1.0.0",
  "private": true,
  "description": "VeriTalent monorepo — frontend, backend, and mobile apps",
  "scripts": {
    "install:backend": "npm ci --prefix backend",
    "install:frontend": "npm ci --prefix frontend",
    "install:mobile": "npm ci --prefix mobile",
    "install:all": "npm run install:backend && npm run install:frontend && npm run install:mobile",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:mobile": "npm run start --prefix mobile",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "lint:frontend": "npm run lint --prefix frontend",
    "lint:backend": "npm run lint --prefix backend",
    "typecheck:mobile": "npm run typecheck --prefix mobile",
    "test:all": "npm run build:backend && npm run build:frontend && npm run typecheck:mobile",
    "ci:stack": "docker compose -f docker-compose.ci.yml up --build",
    "ci:stack:down": "docker compose -f docker-compose.ci.yml down -v",
    "submodules:init": "git submodule update --init --recursive",
    "submodules:update": "git submodule update --remote --recursive"
  }
}
